# 数据库连接信息（示例）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=law_ai_app

# 得理开放平台（请到 open.delilegal.com 申请）
DELI_APPID=
DELI_SECRET=

# 腾讯元器智能体 API（智能体调试页 -> 应用发布 -> API管理 获取）
# 注意：YUANQI_ASSISTANT_ID 填智能体 appid（不要填体验链接URL）
YUANQI_ASSISTANT_ID=
YUANQI_APPKEY=
YUANQI_API_BASE=https://yuanqi.tencent.com

# JWT密钥
JWT_SECRET=

# 服务器端口
PORT=3000

